# Sakoon AI — Environment Variables Reference
# Copy this file to `.env` for local scripts that use python-dotenv,
# OR (preferred, since this is a Streamlit app) mirror these same keys
# into `.streamlit/secrets.toml` — both files are gitignored, never commit
# real values in either.

# --- Groq API ---------------------------------------------------------
# Used by sakoon.services.chatbot (LLM chat + Whisper STT).
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional model overrides (defaults shown)
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile
# GROQ_NARRATIVE_MODEL=llama-3.1-8b-instant
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Cap conversation turns sent to Groq (cost/latency control)
# MAX_HISTORY_MESSAGES=24

# --- Gmail SMTP (for emailer) -----------------------------------------
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password_here
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465

# --- Logging ----------------------------------------------------------
# LOG_LEVEL=INFO

# --- Ops (Phase 6) ----------------------------------------------------
# Writable data directory for SQLite + backups (Docker sets /data)
# DATA_DIR=/data
# RATE_LIMIT_CHAT_PER_MIN=20
# RATE_LIMIT_AUTH_PER_MIN=10
# BACKUP_KEEP=14

# --- Journal encryption (Phase 5, optional but recommended) -----------
# Fernet key (url-safe base64). Generate once and keep secret:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Without this key, journal bodies are stored as plaintext.
# ENCRYPTION_KEY=your_fernet_key_here

# --- Notes --------------------------------------------------------------
# - Never commit a real .env or .streamlit/secrets.toml.
# - On Streamlit Community Cloud, set the same keys in Secrets panel.
# - Missing/invalid keys should degrade gracefully (DESIGN.md §8).
# - Auth uses bcrypt-hashed passwords in SQLite (username + password).
# - Docker: `docker compose up --build` then open http://localhost:8501
# - Backup: `python scripts/backup_db.py` or `docker compose run --rm backup`
