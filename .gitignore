# Sakoon AI — gitignore

# Secrets — NEVER commit these
.streamlit/secrets.toml
.env
.env.*
env (1)
env (*)*

# Database
sakoon.db
backups/
data/

# Python build artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.pytest_cache/

# Generated PDF reports
*.pdf

# Virtual environments
venv/
.venv/
env/

# OS artifacts
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Keep .streamlit/config.toml shareable; secrets stay ignored above
