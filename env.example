# Sakoon AI — Environment Variables Reference
# Copy this file to `.env` for local scripts that use python-dotenv,
# OR (preferred, since this is a Streamlit app) mirror these same keys
# into `.streamlit/secrets.toml` — both files are gitignored, never commit
# real values in either.

# --- Groq API ---------------------------------------------------------
# Used by chatbot.py (LLM chat, JSON mode) and for Whisper transcription
# (voice input pipeline). Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- Gmail SMTP (for emailer.py) --------------------------------------
# The Gmail account that will send wellness report emails.
EMAIL_ADDRESS=your_email@gmail.com

# A Gmail "App Password" (16 characters, no spaces) — NOT your normal
# Gmail login password. Generate one at:
# https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification enabled on the Google account.)
EMAIL_APP_PASSWORD=your_16_char_app_password_here

# --- Notes --------------------------------------------------------------
# - Never commit a real .env or .streamlit/secrets.toml — both must stay
#   in .gitignore.
# - On Streamlit Community Cloud, set these same three keys in the app's
#   "Secrets" panel (Settings → Secrets) instead of shipping a file at all.
# - If a key is missing/invalid, the app should degrade gracefully per
#   DESIGN.md §8 (e.g. SMTP failure -> warning banner, PDF download still
#   works) rather than crashing.
